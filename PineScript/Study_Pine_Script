plotshape(series=((_show_signal == 1) and (bear_cnt == 3 and micro_gap(-1) == true and bear_fade_atr_arr==false)), size=size.tiny, style= shape.arrowdown, color = color.orange)
plotshape(series=((_show_signal == 1) and (bear_cnt == 3 and micro_gap(-1) == false and bear_fade_atr_arr==false)), size=size.tiny, style= shape.circle, color = color.orange)

// ATR signal
plotshape(series=((_show_signal == 1) and (bull_atr_arr[0]==2)) , size=size.tiny, style= shape.diamond, color = color.blue ,location = location.belowbar)
plotshape(series=((_show_signal == 1) and (bull_atr_arr[0]==1)) , size=size.tiny, style= shape.arrowup, color = color.blue ,location = location.belowbar)

plotshape(series=((_show_signal == 1) and (bear_atr_arr[0]==2)) , size=size.tiny, style= shape.diamond, color = color.orange,location = location.belowbar)
plotshape(series=((_show_signal == 1) and (bear_atr_arr[0]==1)) , size=size.tiny, style= shape.arrowdown, color = color.orange,location = location.belowbar)


// Weak fade ATR signal
plotshape(series=((_show_signal == 1) and (bull_fade_atr_arr)), size=size.tiny, style= shape.xcross, color = color.rgb(248, 5, 5))
plotshape(series=((_show_signal == 1) and (bear_fade_atr_arr)), size=size.tiny, style= shape.xcross, color = color.rgb(248, 5, 5))



