if timeframe.isdaily
    count:=(dayofmonth)
else if is_new_day()
    count := 1
else
    count := count + 1

if (count % c_contador == 0 or count == 1)
    label1 = label.new(bar_index, 0, style=label.style_none, text=str.tostring(count))
