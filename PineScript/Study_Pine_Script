    label.set_textcolor(label_bull, textcolor= color.blue)
    label.set_yloc(label_bull, yloc.abovebar)
    label.set_size(label_bull, size.normal)

plotshape(series=((_show_signal == 1) and (bull_cnt == 3 and micro_gap(1) == true and bull_fade_atr_arr==false)) , size=size.tiny, style= shape.arrowup, color = color.blue)
plotshape(series=((_show_signal == 1) and (bull_cnt == 3 and micro_gap(1) == false and bull_fade_atr_arr==false)) , size=size.tiny, style= shape.circle, color = color.blue)

// 3cc bear signal
if (_show_signal == 1 and (bear_cnt >= 3 or bear_atr_arr[0]>0))
    // log.info("bull cnt: {0}", bull_cnt)
    label_bear = label.new(bar_index, 0, style=label.style_none, text=str.tostring(bear_cnt))

    if(bear_cnt == 3)
        label_bear := label.new(bar_index, 0, style=label.style_none, text=str.tostring(bear_cnt), textalign = text.align_left, tooltip = detail) 

    label.set_textcolor(label_bear, textcolor= color.rgb(197, 85, 0))
    label.set_yloc(label_bear, yloc.abovebar)
