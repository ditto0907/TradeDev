{
  "manifest_version": 3,
  "name": "Scroll Catcher",
  "version": "1.0",
  "description": "实时捕获滚动加载的 DIV 内容",
  
  "permissions": ["storage", "activeTab", "downloads", "scripting"],
  "host_permissions": ["<all_urls>"],
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "导出捕获结果"
  },
  
  "background": {
    "service_worker": "background.js"
  }
}
